function GitAud(soundgit, filename)
    local file = filename..".mp3"
    
    if not isfile(file) then
        writefile(file, game:HttpGet(soundgit))
    end

    local asset = (getcustomasset or getsynasset)(file)

    return asset
end

function CustomGitSound(soundlink, volume, distance, filename, soundName, parent, looped)
    local sound = Instance.new("Sound")

    sound.SoundId = GitAud(soundlink, filename)
    sound.Parent = parent or workspace
    sound.Volume = volume or 1
    sound.RollOffMaxDistance = distance or 100
    sound.RollOffMinDistance = 5
    sound.PlaybackSpeed = 1
    sound.Name = soundName or "bgtheme"
    sound.Looped = looped or false

    sound:Play()
    
    sound.Ended:Connect(function() 
    sound:Destroy() 
    end) 

    return sound
end

