local function Notify(text1, text2)
	local gui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

	local screen = Instance.new("ScreenGui")
	screen.IgnoreGuiInset = true
	screen.DisplayOrder = 1000000
	screen.ResetOnSpawn = false
	screen.Parent = gui

	local function CreateLabel(posY, text)
		local label = Instance.new("TextLabel")
		label.AnchorPoint = Vector2.new(0.5, 1)
		label.Position = UDim2.new(0.5, 0, posY, 0)
		label.Size = UDim2.new(0, 1200, 0, 24)
		label.BackgroundTransparency = 1
		label.Text = tostring(text)
		label.ZIndex = 1000000100000000000
		label.TextColor3 = Color3.fromRGB(255, 0, 0)
		label.TextStrokeTransparency = 0
		label.TextStrokeColor3 = Color3.new(0, 0, 0)
		label.Font = Enum.Font.GothamBold
		label.TextSize = 36
		label.TextScaled = true
		label.Parent = screen

		local c = Instance.new("UITextSizeConstraint")
		c.MaxTextSize = 40
		c.MinTextSize = 28
		c.Parent = label

		return label
	end

	CreateLabel(0.67, text1)

	task.wait(3)
		if screen.Parent then
			CreateLabel(0.85, text2) -- nằm dưới text đầu
		end

	task.wait(4)
		screen:Destroy()
end

