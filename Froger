local function Hash(Text)
	local Hash = 2166136261

	for i = 1, #Text do
		Hash = bit32.bxor(Hash, string.byte(Text, i))
		Hash = (Hash * 16777619) % 4294967296
	end

	return string.format("%08X", Hash)
end

function GitAud(Url)
	local File = Folder .. "/" .. Hash(Url) .. ".mp3"

	if not isfile(File) then
		writefile(File, game:HttpGet(Url))
	end

	return getsynasset and getsynasset(File)
		or getcustomasset and getcustomasset(File)
		or error("Executor doesn't support custom assets.")
end

function GitCustomSound(Sound, Url)
	local Asset = GitAud(Url)

	Sound.SoundId = Asset
	Sound.Loaded:Wait()

	return Sound
end

